{
    "name": "sistema-vpc-root",
    "version": "1.0.0",
    "description": "Root management for VPC2026",
    "scripts": {
        "install:all": "npm install && npm install --prefix frontend && npm install --prefix backend",
        "dev:frontend": "npm run dev --prefix frontend",
        "dev:backend": "npm run dev --prefix backend",
        "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
        "build": "npm run build --prefix backend && (cd backend && npx prisma generate)",
        "start": "npm run start:prod --prefix backend",
        "postinstall": "npm install --prefix backend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}